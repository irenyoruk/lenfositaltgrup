        parsed = JSON.parse(clean);
      } catch (err) {
        throw new Error("PDF'ten gelen yanıt çözümlenemedi. PDF formatı tanınmıyor olabilir.");
      }

      const importedIds = [];
      const newValues = { ...values };
      Object.entries(parsed.values || {}).forEach(([id, val]) => {
        if (typeof val === "number" && !Number.isNaN(val)) {
          newValues[id] = String(val);
          importedIds.push(id);
        }
      });
      setValues(newValues);

      const birthDt = parseDDMMYYYY(parsed.birth_date);
      const sampleDt = parseDDMMYYYY(parsed.sample_date);
      const autoAgeIdx = computeAgeGroupIdx(birthDt, sampleDt);
