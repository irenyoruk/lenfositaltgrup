      setPatient({
        birth_date: parsed.birth_date || null,
        sample_date: parsed.sample_date || null,
        sex: parsed.sex || null,
        report_no: parsed.report_no || null,
        protocol: parsed.protocol || null,
        ageLabel: formatAge(birthDt, sampleDt),
        ageGroupIdx: autoAgeIdx,
        ageGroupLabel: autoAgeIdx !== null ? AGE_GROUPS[autoAgeIdx].label : null,
        importedIds,
        skipped: parsed.skipped || [],
      });

      setPdfStatus({
        state: "success",
        message: `${importedIds.length} test sonucu içe aktarıldı`
      });
    } catch (err) {
      console.error(err);
      setPdfStatus({ state: "error", message: err.message || "Bilinmeyen hata" });
    } finally {
      e.target.value = "";
    }
