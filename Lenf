function parseDDMMYYYY(s) {
  if (!s || typeof s !== "string") return null;
  const m = s.match(/(\d{1,2})[./-](\d{1,2})[./-](\d{4})/);
  if (!m) return null;
  const [, d, mo, y] = m;
  const dt = new Date(parseInt(y), parseInt(mo) - 1, parseInt(d));
  return isNaN(dt.getTime()) ? null : dt;
}

function computeAgeGroupIdx(birthDate, sampleDate) {
  if (!birthDate || !sampleDate) return null;
  const days = Math.floor((sampleDate - birthDate) / (1000 * 60 * 60 * 24));
  if (days < 0) return null;
  if (days < 40)    return 1;
  if (days < 183)   return 2;
  if (days < 274)   return 3;
  if (days < 366)   return 4;
  if (days < 731)   return 5;
  if (days < 1826)  return 6;
  if (days < 3653)  return 7;
  if (days < 5844)  return 8;
  return 9;
}

function formatAge(birthDate, sampleDate) {
  if (!birthDate || !sampleDate) return "";
  const totalMonths = (sampleDate.getFullYear() - birthDate.getFullYear()) * 12 +
                      (sampleDate.getMonth() - birthDate.getMonth()) -
                      (sampleDate.getDate() < birthDate.getDate() ? 1 : 0);
  if (totalMonths < 0) return "";
  const years = Math.floor(totalMonths / 12);
  const months = totalMonths % 12;
  if (years === 0) return `${months} ay`;
  return `${years} yaş ${months} ay`;
}

function evaluate(value, range) {
  if (value === "" || value === null || value === undefined) return { status: "empty" };
  const v = parseFloat(String(value).replace(",", "."));
  if (Number.isNaN(v)) return { status: "invalid" };
  const [min, max] = range;
  if (min == null && max == null) return { status: "no-ref", value: v };
  if (min != null && v < min) return { status: "low", value: v, diff: min - v };
  if (max != null && v > max) return { status: "high", value: v, diff: v - max };
  return { status: "normal", value: v };
}

const STATUS_STYLES = {
  low:     { bg: "#FEF2F2", border: "#EF4444", text: "#B91C1C", label: "Düşük ↓",   dot: "#EF4444" },
  normal:  { bg: "#F0FDF4", border: "#22C55E", text: "#15803D", label: "Normal ✓",  dot: "#22C55E" },
  high:    { bg: "#EFF6FF", border: "#3B82F6", text: "#1D4ED8", label: "Yüksek ↑",  dot: "#3B82F6" },
  empty:   { bg: "#F8FAFC", border: "#CBD5E1", text: "#64748B", label: "—",          dot: "#CBD5E1" },
  invalid: { bg: "#FEFCE8", border: "#EAB308", text: "#A16207", label: "Geçersiz",  dot: "#EAB308" },
  "no-ref":{ bg: "#F5F3FF", border: "#A78BFA", text: "#6D28D9", label: "Ref. yok",  dot: "#A78BFA" },
};

function formatRange(range) {
  const [min, max] = range;
  if (min == null && max == null) return "—";
  if (max == null) return `≥ ${min}`;
  if (min == null) return `≤ ${max}`;
  return `${min} – ${max}`;
}

